{
	"name": "@chainsafe/zapi",
	"license": "MIT",
	"version": "0.1.1",
	"description": "A tool for managing and publishing Zig NAPI packages.",
	"type": "module",
	"scripts": {
		"build": "pnpm build:js && pnpm build:examples",
		"build:js": "tsc --outDir lib",
		"build:examples": "zig build examples",
		"test:zapi": "zig build test",
		"test:examples": "vitest run examples/**/*.test.ts",
		"test": "pnpm test:zapi && pnpm test:examples",
		"lint:zapi": "zig fmt src",
		"lint:ts": "pnpm biome check",
		"lint": "pnpm lint:zapi && pnpm lint:ts",
		"lint:fix": "pnpm biome check --write"
	},
	"files": [
		"ts",
		"js"
	],
	"bin": "lib/cli.js",
	"exports": {
		".": "./lib/lib.js"
	},
	"types": "lib/lib.d.ts",
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@chainsafe/biomejs-config": "^1.0.0",
		"@types/node": "^24.1.0",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	}
}
