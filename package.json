{
	"name": "@chainsafe/zapi",
	"license": "MIT",
	"version": "0.1.1",
	"description": "A tool for managing and publishing Zig NAPI packages.",
	"type": "module",
	"scripts": {
		"build": "pnpm build:js && pnpm build:zig",
		"build:js": "tsc --outDir lib",
		"build:zig": "zig build",
		"test:zig": "zig build test:zapi",
		"test:js": "vitest run examples/**/*.test.ts",
		"test": "pnpm test:zig && pnpm test:js",
		"lint:zig": "zig fmt src",
		"lint:js": "pnpm biome check",
		"lint": "pnpm lint:zig && pnpm lint:js",
		"lint:fix": "pnpm biome check --write"
	},
	"files": [
		"ts",
		"js"
	],
	"bin": "lib/cli.js",
	"exports": {
		".": "./lib/lib.js"
	},
	"types": "lib/lib.d.ts",
	"devDependencies": {
		"@biomejs/biome": "^2.4.6",
		"@chainsafe/biomejs-config": "^1.0.0",
		"@types/node": "^24.1.0",
		"typescript": "^5.8.3",
		"vitest": "^4.0.18"
	},
	"packageManager": "pnpm@10.8.1+sha512.c50088ba998c67b8ca8c99df8a5e02fd2ae2e2b29aaf238feaa9e124248d3f48f9fb6db2424949ff901cffbb5e0f0cc1ad6aedb602cd29450751d11c35023677"
}
